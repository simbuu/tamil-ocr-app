# Tamil OCR - Environment Configuration
# Copy to .env and edit as needed

# App settings
APP_ENV=development
SECRET_KEY=change-me-in-production

# Database (default: SQLite for local dev, switch to PostgreSQL for prod)
DATABASE_URL=sqlite:///./tamil_ocr.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/tamil_ocr

# OCR settings
USE_GPU=false          # Set true if CUDA GPU available (massive speedup)
OCR_LANGUAGES=ta,en   # Tamil + English

# File upload
MAX_UPLOAD_MB=20
UPLOAD_DIR=app/static/uploads

# AWS S3 (optional - for cloud image storage)
# AWS_BUCKET_NAME=your-bucket
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
